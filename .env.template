# 📸 INSTAGRAM SETTINGS (Scraper & DM Sender)
IG_USERNAME=quail.30381691
IG_PASSWORD=Septiii-123
# Session ID cookie (Bypass checkpoint challenge)
IG_SESSIONID=

# 🤖 AI MODEL CONFIGURATION
# Pilihan tipe AI: 'cloud' (Google Gemini), 'openrouter' (OpenRouter API), atau 'local' (Ollama / LM Studio)
AI_TYPE=cloud

# Tipe 1: Google Gemini (Cloud API)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Tipe 2: OpenRouter API
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-2-9b-it:free

# Tipe 3: Local LLM (Ollama / LM Studio)
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=gemma4:e4b

# 📧 COLD EMAIL OUTREACH SETTINGS
# Pilihan tipe pengiriman: 'smtp' atau 'hostinger'
EMAIL_SERVICE_TYPE=smtp

# Opsi 1: Hostinger Agentic Mail REST API
HOSTINGER_API_TOKEN=

# Opsi 2: Standard SMTP (Gmail, Outlook, dsb)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
# Sandi Aplikasi (App Password), bukan password utama email Anda untuk keamanan!
SMTP_PASS=your_app_password
SMTP_FROM_NAME=DripCode Web Development

